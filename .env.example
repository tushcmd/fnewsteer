# Copy this file to .env and fill in your values.
# The app loads this automatically via python-dotenv.

# Required: Set a strong random string. The bot must send this in the X-API-Key header.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FNEWSTEER_API_KEY=your-secret-api-key-here

# ── Optional ──────────────────────────────────────────────────────────────────

# SSE server bind address and port (SSE transport only)
MCP_SSE_HOST=0.0.0.0
MCP_SSE_PORT=8001
